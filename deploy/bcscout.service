[Unit]
Description=BC Backcountry Scout Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/bc-backcountry-scout
EnvironmentFile=/home/ubuntu/bc-backcountry-scout/.env
ExecStart=/home/ubuntu/bc-backcountry-scout/venv/bin/python bot.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
